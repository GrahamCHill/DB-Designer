{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DB Designer",
  "version": "1.0.3",
  "identifier": "dev.grahamhill.db-designer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "__TAURI_UPDATER_PUBLIC_KEY__",
      "endpoints": [
        "https://github.com/GrahamCHill/DB-Designer/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "DB Designer",
        "width": 1200,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null
    }
  }
}
